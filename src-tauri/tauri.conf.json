{
  "package": {
    "productName": "meTV",
    "version": "0.1.3"
  },
  "build": {
    "devPath": "https://metv.pages.dev",
    "distDir": "https://metv.pages.dev"
  },
  "tauri": {
    "bundle": {
      "active": true,
      "targets": "all",
      "identifier": "dev.appjava.metv",
      "icon": [
        "icons/32x32.png",
        "icons/128x128.png",
        "icons/128x128@2x.png",
        "icons/icon.icns",
        "icons/icon.ico"
      ],
      "linux": {
        "appimage": {
          "bundleMediaFramework": true
        }
      }        
    },
    "allowlist": {
      "all": true
    },
    "windows": [
      {
        "title": "meTV+",
        "width": 360,
        "height": 480,
        "resizable": true
      }
    ]
  }
}